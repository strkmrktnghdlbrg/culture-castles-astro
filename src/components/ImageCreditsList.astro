---
/**
 * Rendert einen kompakten "Bildnachweis"-Block (CC-Pflicht).
 * Props-basiert: bekommt die Credits direkt übergeben (aus Content-
 * Collection-Frontmatter), statt aus einem zentralen Daten-Modul.
 */
export type CreditEntry = {
  label: string;
  author: string;
  license?: string;
  licenseUrl?: string;
  sourceUrl?: string;
};

interface Props {
  credits: (CreditEntry | null | undefined)[];
  heading?: string;
}
const { credits, heading = "Bildnachweise" } = Astro.props;
const entries = (credits ?? []).filter((c): c is CreditEntry => !!c && !!c.author);
---
{entries.length > 0 && (
  <section class="container-page pb-10 pt-2">
    <details class="text-xs" style="color: var(--cc-text-mute);">
      <summary class="cursor-pointer font-semibold inline-flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        {heading} ({entries.length})
      </summary>
      <ul class="mt-3 grid sm:grid-cols-2 gap-x-6 gap-y-1.5">
        {entries.map((c) => (
          <li class="leading-snug">
            <span class="font-medium">{c.label}:</span>
            &nbsp;Foto&nbsp;
            {c.sourceUrl ? (
              <a href={c.sourceUrl} class="link-accent" rel="nofollow noopener" target="_blank">{c.author}</a>
            ) : (
              <span>{c.author}</span>
            )}
            {c.license && (
              <>
                ,&nbsp;
                {c.licenseUrl ? (
                  <a href={c.licenseUrl} class="link-accent" rel="nofollow noopener" target="_blank">{c.license}</a>
                ) : (
                  <span>{c.license}</span>
                )}
              </>
            )}
          </li>
        ))}
      </ul>
    </details>
  </section>
)}

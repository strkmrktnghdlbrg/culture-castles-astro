---
import CastleImage from "./CastleImage.astro";

interface Props {
  href: string;
  title: string;
  region?: string;
  teaser?: string;
  image?: string;
  imageAlt?: string;
  rank?: number;
  type?: string;
}

const { href, title, region, teaser, image, imageAlt, rank, type } = Astro.props;
---

<a href={href} class="castle-card">
  <div class="castle-card__image-wrap">
    <CastleImage
      src={image}
      alt={imageAlt ?? title}
      class="castle-card__image"
    />
    {rank && (
      <div class="castle-card__rank">
        <span>{rank}</span>
      </div>
    )}
  </div>

  <div class="castle-card__body">
    {region && (
      <p class="castle-card__eyebrow">{region}</p>
    )}
    <h3 class="castle-card__title">{title}</h3>
    {teaser && (
      <p class="castle-card__teaser">{teaser}</p>
    )}
    <span class="castle-card__cta">Profil ansehen →</span>
  </div>
</a>

<style>
  .castle-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--cc-line);
    background: var(--cc-bg-2);
    border-radius: 0;
    text-decoration: none;
    color: var(--cc-text);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .castle-card:hover {
    border-color: var(--cc-accent);
    transform: translateY(-3px);
  }

  .castle-card__image-wrap {
    position: relative;
    height: 13rem; /* h-52 */
    flex-shrink: 0;
    overflow: hidden;
  }

  .castle-card__image {
    width: 100%;
    height: 100%;
    border-radius: 0;
  }

  .castle-card__rank {
    position: absolute;
    top: 0;
    left: 0;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--cc-accent);
    background: var(--cc-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
  }

  .castle-card__rank span {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--cc-accent);
    line-height: 1;
  }

  .castle-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    flex: 1;
  }

  .castle-card__eyebrow {
    font-family: var(--font-aux);
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.36em;
    color: var(--cc-accent);
    margin: 0;
  }

  .castle-card__title {
    font-family: var(--font-display);
    font-size: 1.6875rem; /* 27px */
    font-weight: 300;
    color: var(--cc-text);
    margin: 0;
    line-height: 1.2;
  }

  .castle-card__teaser {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--cc-text-soft);
    margin: 0;
    line-height: 1.6;
    flex: 1;
  }

  .castle-card__cta {
    font-family: var(--font-aux);
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--cc-accent);
    margin-top: 0.5rem;
  }

  .castle-card:hover .castle-card__cta {
    color: var(--cc-accent-hi);
  }
</style>

---
import CastleImage from "./CastleImage.astro";

interface MetaItem {
  label: string;
  value: string;
}

interface Props {
  href: string;
  title: string;
  image: string;
  place?: string;
  epoch?: string;
  teaser: string;
  meta?: MetaItem[];
  tagLabel?: string;
}

const { href, title, image, place, epoch, teaser, meta, tagLabel } = Astro.props;
---

<div class="feature">
  <!-- Media column -->
  <div class="feature-media">
    {tagLabel && <span class="feature-tag">{tagLabel}</span>}
    <CastleImage
      src={image}
      alt={title}
      class="feature-img"
    />
  </div>

  <!-- Body column -->
  <div class="feature-body">
    {place && <span class="feature-place">{place}</span>}
    <h3 class="feature-title">{title}</h3>
    {epoch && <div class="feature-epoch">{epoch}</div>}
    <p class="feature-teaser">{teaser}</p>

    {meta && meta.length > 0 && (
      <div class="feature-meta">
        {meta.map((item) => (
          <div class="feature-meta-item">
            <b>{item.value}</b>
            {item.label}
          </div>
        ))}
      </div>
    )}

    <div class="feature-actions">
      <a href={href} class="btn-filled">Profil ansehen</a>
      <a href={href} class="btn-ghost">Tickets &amp; Führungen</a>
    </div>
  </div>
</div>

<style>
  .feature {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 0;
    border: 1px solid var(--cc-line);
    border-radius: 0;
  }

  .feature-media {
    position: relative;
    min-height: 440px;
    overflow: hidden;
  }

  .feature-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
  }

  /* darken the photo slightly for readability */
  .feature-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(42, 18, 26, 0.22);
    pointer-events: none;
  }

  .feature-tag {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    background: var(--cc-accent);
    color: var(--cc-bg);
    font-family: var(--font-aux);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: 12px;
    padding: 8px 16px;
    border-radius: 0;
  }

  .feature-body {
    padding: 52px 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--cc-bg-2);
  }

  .feature-place {
    font-family: var(--font-aux);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: 12px;
    color: var(--cc-accent);
  }

  .feature-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 46px;
    line-height: 1.02;
    color: var(--cc-text);
    margin: 14px 0 6px;
    border-radius: 0;
  }

  .feature-epoch {
    font-family: var(--font-serif2);
    font-style: italic;
    color: var(--cc-text-soft);
    font-size: 18px;
    margin-bottom: 22px;
  }

  .feature-teaser {
    color: var(--cc-text-soft);
    font-size: 17px;
    line-height: 1.65;
    margin: 0;
  }

  .feature-meta {
    display: flex;
    gap: 30px;
    margin: 28px 0 30px;
    flex-wrap: wrap;
  }

  .feature-meta-item {
    font-family: var(--font-aux);
    font-size: 13px;
    color: var(--cc-text-soft);
  }

  .feature-meta-item b {
    display: block;
    color: var(--cc-text);
    font-size: 15px;
    letter-spacing: 0.06em;
    margin-bottom: 3px;
    font-weight: 400;
  }

  .feature-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  /* Gold-filled primary button */
  .btn-filled {
    display: inline-block;
    background: var(--cc-accent);
    color: var(--cc-bg);
    border: 1px solid var(--cc-accent);
    font-family: var(--font-aux);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 13px;
    font-weight: 400;
    padding: 10px 22px;
    border-radius: 0;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .btn-filled:hover {
    background: var(--cc-accent-hi);
    border-color: var(--cc-accent-hi);
    color: var(--cc-bg);
  }

  /* Ghost button (from brand.css via global) – repeat here for scoped safety */
  .btn-ghost {
    display: inline-block;
    background: transparent;
    color: var(--cc-text);
    border: 1px solid var(--cc-text);
    font-family: var(--font-aux);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 13px;
    font-weight: 400;
    padding: 10px 22px;
    border-radius: 0;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--cc-accent);
    color: var(--cc-accent);
  }

  /* Mobile: stack columns */
  @media (max-width: 860px) {
    .feature {
      grid-template-columns: 1fr;
    }

    .feature-media {
      min-height: 300px;
    }

    .feature-body {
      padding: 36px 28px;
    }

    .feature-title {
      font-size: 34px;
    }
  }
</style>

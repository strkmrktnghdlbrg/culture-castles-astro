---
interface Props {
  src?: string;
  alt: string;
  class?: string;
}

const { src, alt, class: className } = Astro.props;
---

<div
  class={className}
  style="background: var(--hue-1); border-radius: 0;"
>
  {src && (
    <img
      src={src}
      alt={alt}
      loading="lazy"
      onerror="this.style.display='none'"
      style="width:100%;height:100%;object-fit:cover;display:block;border-radius:0;"
    />
  )}
</div>

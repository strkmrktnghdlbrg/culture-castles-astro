---
import { site } from "../data/site";
interface Crumb { label: string; href?: string }
interface Props { items: Crumb[] }
const { items } = Astro.props;

// BreadcrumbList JSON-LD (absolute URLs). Deckt automatisch alle Seiten ab,
// die Breadcrumbs nutzen (Burg-, Artikel-, Region-, Routen-, Legacy-Seiten).
const abs = (h?: string) =>
  new URL(h ?? Astro.url.pathname, site.domain).toString();
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((c, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: c.label,
    item: abs(c.href),
  })),
};
---
<nav aria-label="Breadcrumb" class="text-xs" style="color: var(--color-slate-steel);">
  <ol class="flex flex-wrap items-center gap-1.5">
    {items.map((c, i) => (
      <li class="flex items-center gap-1.5">
        {c.href ? (
          <a href={c.href} class="hover:underline" style="color: var(--color-shadow-graphite);">{c.label}</a>
        ) : (
          <span aria-current={i === items.length - 1 ? "page" : undefined}>{c.label}</span>
        )}
        {i < items.length - 1 && <span aria-hidden="true">›</span>}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)} />

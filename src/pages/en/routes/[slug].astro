---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CastleImage from "../../../components/CastleImage.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import Band from "../../../components/Band.astro";
import OrnamentRule from "../../../components/OrnamentRule.astro";
import StaySection from "../../../components/StaySection.astro";
import { site } from "../../../data/site";

export async function getStaticPaths() {
  const entries = await getCollection("routesEn");
  return entries.map((e) => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, heroImage, teaser, distanceKm, stops, days, etappen } = entry.data;
const slug = entry.id;

// English castle slugs available, to know which stages can be linked
const enCastles = await getCollection("castlesEn");
const enCastleIds = new Set(enCastles.map((c) => c.id));

const metaParts: string[] = [];
if (stops != null) metaParts.push(`${stops} stops`);
if (distanceKm != null) metaParts.push(`${distanceKm} km`);
if (days) metaParts.push(days);
const metaLine = metaParts.join(" · ");
---

<BaseLayout
  title={title}
  description={teaser}
  ogImage={heroImage || undefined}
  lang="en"
  alternates={[
    { hreflang: "de", href: new URL(`/routen/${slug}/`, site.domain).toString() },
    { hreflang: "en", href: new URL(`/en/routes/${slug}/`, site.domain).toString() },
  ]}
>
  <div class="container-page" style="padding: 1.5rem 0;">
    <Breadcrumbs
      items={[{ label: "Home", href: "/en/" }, { label: "Routes", href: "/en/routes/" }, { label: title }]}
    />
  </div>

  <header style="position: relative; min-height: 60vh; overflow: hidden; display: flex; align-items: flex-end;">
    <CastleImage src={heroImage || ""} alt={title} class="cc-en-routebg" />
    <div style="position:absolute; inset:0; background: linear-gradient(180deg, rgba(42,18,26,.4), rgba(42,18,26,.92));"></div>
    <div class="container-page" style="position:relative; padding-bottom:2.5rem;">
      {metaLine && <p style="font-family: var(--font-aux); letter-spacing:.24em; text-transform:uppercase; font-size:12px; color: var(--cc-accent); margin-bottom:.75rem;">{metaLine}</p>}
      <h1 style="font-family: var(--font-display); font-weight:300; font-size: clamp(2.5rem,6vw,4.5rem); line-height:1.02; color: var(--cc-text); margin:0; max-width:18ch;">{title}</h1>
    </div>
  </header>

  <Band>
    <div class="route-prose"><Content /></div>
  </Band>

  {etappen.length > 0 && (
    <Band soft>
      <OrnamentRule label="The route" />
      <ol class="etappen">
        {etappen.map((e, i) => (
          <li class="etappe">
            <span class="etappe-num">{i + 1}</span>
            <div>
              <h3 class="etappe-title">
                {e.castle && enCastleIds.has(e.castle)
                  ? <a href={`/en/castles/${e.castle}/`}>{e.title}</a>
                  : e.title}
              </h3>
              {e.note && <p class="etappe-note">{e.note}</p>}
            </div>
          </li>
        ))}
      </ol>
    </Band>
  )}

  <StaySection
    title="Where to stay along the route"
    lead="Find well-placed hotels and guesthouses for each stage of your castle journey — from castle hotels to charming inns."
  />
</BaseLayout>

<style>
  header :global(.cc-en-routebg) { position:absolute; inset:0; width:100%; height:100%; }
  header :global(.cc-en-routebg img) { filter: saturate(.65) brightness(.6); }
  .route-prose { max-width: 72ch; margin-inline:auto; font-family: var(--font-sans); font-size:1.0625rem; line-height:1.75; color: var(--cc-text-soft); }
  .route-prose :global(h2) { font-family: var(--font-display); font-weight:300; font-size: clamp(1.6rem,3vw,2.2rem); color: var(--cc-text); margin:2.5rem 0 .75rem; }
  .route-prose :global(p) { margin-bottom:1.25rem; }
  .route-prose :global(a) { color: var(--cc-accent); text-decoration: underline; text-underline-offset:3px; }
  .etappen { list-style:none; padding:0; margin:2.5rem auto 0; max-width:60ch; display:flex; flex-direction:column; gap:1.5rem; }
  .etappe { display:flex; gap:1.25rem; align-items:flex-start; }
  .etappe-num { flex-shrink:0; width:2.5rem; height:2.5rem; display:grid; place-items:center; border:1px solid var(--cc-accent); color: var(--cc-accent); font-family: var(--font-display); font-size:1.25rem; }
  .etappe-title { font-family: var(--font-display); font-weight:300; font-size:1.5rem; color: var(--cc-text); margin:.2rem 0 .35rem; }
  .etappe-title :global(a) { color: var(--cc-accent); text-decoration:none; }
  .etappe-title :global(a:hover) { text-decoration:underline; text-underline-offset:3px; }
  .etappe-note { font-family: var(--font-sans); color: var(--cc-text-soft); line-height:1.6; margin:0; }
</style>

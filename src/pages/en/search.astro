---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

// ── Build-time index (English collections) ────────────────────────────────────
const castles  = await getCollection("castlesEn");
const routes   = await getCollection("routesEn");
const articles = await getCollection("articlesEn");

interface IndexEntry {
  title: string;
  kind: "castle" | "route" | "article";
  href: string;
  teaser: string;
}

const index: IndexEntry[] = [
  ...castles.map((e) => ({
    title:  e.data.title,
    kind:   "castle"  as const,
    href:   `/en/castles/${e.id}/`,
    teaser: e.data.teaser ?? "",
  })),
  ...routes.map((e) => ({
    title:  e.data.title,
    kind:   "route"   as const,
    href:   `/en/routes/${e.id}/`,
    teaser: e.data.teaser ?? "",
  })),
  ...articles
    .filter((a) => !a.data.draft)
    .map((e) => ({
      title:  e.data.title,
      kind:   "article" as const,
      href:   `/en/magazine/${e.id}/`,
      teaser: e.data.teaser ?? "",
    })),
];
---

<BaseLayout
  title="Search"
  description="Search castles, palaces, routes and magazine articles on Culture Castles."
  lang="en"
  noindex={true}
>
  <!-- Embed the full index for client-side search -->
  <script is:inline define:vars={{ index }}>
    window.__CC_INDEX__ = index;
  </script>

  <section
    style="
      min-height: 100vh;
      background: var(--cc-bg);
      color: var(--cc-text);
      padding: 6rem 1.25rem 5rem;
    "
  >
    <div
      class="container-page"
      style="max-width: 780px; margin: 0 auto;"
    >
      <!-- Kicker -->
      <p
        style="
          font-family: var(--font-aux);
          font-size: 11px;
          letter-spacing: 0.38em;
          text-transform: uppercase;
          color: var(--cc-accent);
          margin-bottom: 1rem;
        "
      >
        Search
      </p>

      <!-- Headline -->
      <h1
        style="
          font-family: var(--font-display);
          font-weight: 300;
          font-size: clamp(34px, 6vw, 60px);
          color: var(--cc-text);
          margin: 0 0 2.5rem;
          line-height: 1.1;
        "
      >
        Discover castles<br />
        <em style="color: var(--cc-accent); font-style: italic;">&amp; palaces</em>
      </h1>

      <!-- Ornamental rule -->
      <div class="cc-rule" style="margin-bottom: 2.5rem;">
        <span class="mark">Search</span>
      </div>

      <!-- Search form -->
      <form
        id="cc-search-form"
        action="/en/search/"
        method="get"
        style="display: flex; gap: 0; margin-bottom: 3rem;"
      >
        <input
          id="cc-search-input"
          type="search"
          name="q"
          placeholder="e.g. Neuschwanstein, Bavaria, fortress …"
          autocomplete="off"
          style="
            flex: 1;
            background: var(--cc-bg-2);
            border: 1px solid var(--cc-line);
            border-right: none;
            color: var(--cc-text);
            font-family: var(--font-sans);
            font-size: 1rem;
            padding: 0.85rem 1.1rem;
            outline: none;
            border-radius: 0;
            appearance: none;
          "
        />
        <button
          type="submit"
          style="
            background: var(--cc-accent);
            color: var(--cc-bg);
            border: 1px solid var(--cc-accent);
            font-family: var(--font-aux);
            font-size: 11px;
            letter-spacing: 0.26em;
            text-transform: uppercase;
            padding: 0 1.5rem;
            cursor: pointer;
            border-radius: 0;
            white-space: nowrap;
          "
        >
          Search
        </button>
      </form>

      <!-- Status line -->
      <p
        id="cc-search-status"
        style="
          font-family: var(--font-aux);
          font-size: 11px;
          letter-spacing: 0.28em;
          text-transform: uppercase;
          color: var(--cc-text-mute);
          margin-bottom: 1.75rem;
          min-height: 1.4em;
        "
      >
      </p>

      <!-- Results list -->
      <ul
        id="cc-results"
        style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0;"
      >
      </ul>

      <!-- Empty state (hidden by default, shown by JS) -->
      <div
        id="cc-empty"
        hidden
        style="
          border: 1px solid var(--cc-line);
          padding: 3rem 2rem;
          text-align: center;
          color: var(--cc-text-soft);
        "
      >
        <p
          style="
            font-family: var(--font-display);
            font-size: 1.6rem;
            font-weight: 300;
            margin: 0 0 0.75rem;
            color: var(--cc-text);
          "
        >
          No results found.
        </p>
        <p style="font-family: var(--font-sans); font-size: 0.95rem; margin: 0;">
          Try a different search term or browse the
          <a
            href="/en/#castles"
            style="color: var(--cc-accent); text-decoration: underline;"
            >castles &amp; palaces</a
          >.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  #cc-search-input:focus {
    border-color: var(--cc-accent);
    outline: none;
  }
  #cc-search-input::placeholder {
    color: var(--cc-text-mute);
  }

  .cc-result-item {
    border-top: 1px solid var(--cc-line);
    padding: 1.35rem 0;
    transition: border-color 0.15s;
  }
  .cc-result-item:last-child {
    border-bottom: 1px solid var(--cc-line);
  }
  .cc-result-item:hover {
    border-top-color: var(--cc-accent);
  }
  .cc-result-kind {
    font-family: var(--font-aux);
    font-size: 10px;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--cc-accent);
    margin-bottom: 0.3rem;
  }
  .cc-result-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 1.55rem;
    color: var(--cc-text);
    text-decoration: none;
    display: block;
    line-height: 1.2;
    margin-bottom: 0.35rem;
    transition: color 0.15s;
  }
  .cc-result-title:hover {
    color: var(--cc-accent-hi);
  }
  .cc-result-teaser {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--cc-text-soft);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script is:inline>
(function () {
  var KIND_LABEL = { castle: "Castle & Palace", route: "Route", article: "Magazine" };

  function getQ() {
    return new URLSearchParams(window.location.search).get("q") || "";
  }

  function highlight(text, q) {
    if (!q) return text;
    var escaped = q.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    return text.replace(new RegExp("(" + escaped + ")", "gi"), "<mark style=\"background:rgba(205,171,109,0.25);color:var(--cc-accent-hi)\">$1</mark>");
  }

  function render(q) {
    var input  = document.getElementById("cc-search-input");
    var status = document.getElementById("cc-search-status");
    var list   = document.getElementById("cc-results");
    var empty  = document.getElementById("cc-empty");
    var idx    = window.__CC_INDEX__ || [];

    if (input) input.value = q;

    if (!q || q.length < 2) {
      if (status) status.textContent = q ? "Type at least 2 characters …" : "Type a search term to start.";
      if (list)  list.innerHTML = "";
      if (empty) empty.hidden = true;
      return;
    }

    var lc = q.toLowerCase();
    var hits = idx.filter(function (e) {
      return (
        (e.title  && e.title.toLowerCase().indexOf(lc)  !== -1) ||
        (e.teaser && e.teaser.toLowerCase().indexOf(lc) !== -1)
      );
    });

    if (status) status.textContent = hits.length
      ? hits.length + " result" + (hits.length === 1 ? "" : "s") + " for “" + q + "”"
      : "No results for “" + q + "”";

    if (hits.length === 0) {
      if (list)  list.innerHTML = "";
      if (empty) empty.hidden = false;
      return;
    }

    if (empty) empty.hidden = true;
    if (list) {
      list.innerHTML = hits.map(function (e) {
        var kindLabel = KIND_LABEL[e.kind] || e.kind;
        var teaserHl  = highlight(e.teaser || "", q);
        var titleHl   = highlight(e.title  || "", q);
        return (
          "<li class=\"cc-result-item\">" +
            "<div class=\"cc-result-kind\">" + kindLabel + "</div>" +
            "<a class=\"cc-result-title\" href=\"" + e.href + "\">" + titleHl + "</a>" +
            (e.teaser ? "<p class=\"cc-result-teaser\">" + teaserHl + "</p>" : "") +
          "</li>"
        );
      }).join("");
    }
  }

  var q = getQ();
  render(q);

  var timer;
  var input = document.getElementById("cc-search-input");
  if (input) {
    input.addEventListener("input", function () {
      clearTimeout(timer);
      var val = input.value.trim();
      timer = setTimeout(function () { render(val); }, 220);
    });
  }
})();
</script>

---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Band from "../../components/Band.astro";
import SectionHead from "../../components/SectionHead.astro";
import MagazineCard from "../../components/MagazineCard.astro";
import OrnamentRule from "../../components/OrnamentRule.astro";

// Fetch all non-draft articles, sorted by date descending
const allArticles = await getCollection("articles");
const articles = allArticles
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Magazin"
  description="Geschichten, Ratgeber und Fotografietipps rund um Burgen und Schlösser in Deutschland und Europa — im Magazin von Culture Castles."
>
  <!-- Intro Band -->
  <Band>
    <SectionHead
      kicker="Aus unserer Redaktion"
      title="Magazin"
      subtitle="Geschichten aus Stein und Geschichte: Ratgeber für Burgbesuche, Fotografie-Tipps und Hintergründe zu tausend Jahren europäischer Burgenkultur."
    />
  </Band>

  <OrnamentRule label="Alle Beiträge" />

  <!-- Article list -->
  <Band soft>
    {articles.length > 0 ? (
      <div class="magazine-list">
        {articles.map((entry) => (
          <MagazineCard
            href={`/magazin/${entry.id}/`}
            title={entry.data.title}
            date={entry.data.date.toISOString()}
            category={entry.data.category}
            teaser={entry.data.teaser}
          />
        ))}
      </div>
    ) : (
      <p class="magazine-empty">
        Noch keine Beiträge verfügbar — schauen Sie bald wieder vorbei.
      </p>
    )}
  </Band>
</BaseLayout>

<style>
  .magazine-list {
    max-width: 820px;
    margin-inline: auto;
  }

  /* Remove top border on first card so the OrnamentRule serves as visual divider */
  .magazine-list > :global(.magazine-card:first-child) {
    border-top: none;
  }

  .magazine-empty {
    font-family: var(--font-sans);
    color: var(--cc-text-soft);
    text-align: center;
    padding: 4rem 0;
  }
</style>
